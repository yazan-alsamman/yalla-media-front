# Laravel API — same backend for dashboard + mobile app.
#
# Production / remote API (absolute URL; bypasses Vite proxy):
# VITE_API_URL=https://salmon-mouse-246850.hostingersite.com/api
#
# Local dev: leave empty to use same-origin /api (vite.config.ts → http://127.0.0.1:8000).
# Ensure config/cors.php allows your dashboard origin when using a remote API.
#
# Optional: Laravel public URL for uploaded files (/storage/...). Defaults to stripping /api from VITE_API_URL.
# Example local: VITE_BACKEND_PUBLIC_URL=http://127.0.0.1:8000

VITE_API_URL=https://salmon-mouse-246850.hostingersite.com/api
